# Google Cloud Project Identifier
# Format: 12-digit numeric project number or string project ID
GCP_PROJECT_ID="your-project-id"

# Google Cloud Deployment Region
# Example: us-central1
GCP_REGION="us-central1"

# Gemini API Key for diagnostic and LLM-as-a-Judge phases
# Obtain from Google AI Studio or Vertex AI
GEMINI_API_KEY="AIzaSy..."

# Google Agent Platform API Key for Vertex AI execution
GOOGLE_AGENT_PLATFORM_API_KEY="AQ..."

# Arize Phoenix API Key for trace export and MCP integration
# Format: JWT or standard API key string
PHOENIX_API_KEY="eyJ..."

# Arize Phoenix Workspace Identifier
# Required for get-spans MCP tool context routing
ARIZE_SPACE_ID="U3..."

# Google Cloud Model Armor Configuration
# Project ID hosting the Model Armor service
GOOGLE_CLOUD_PROJECT="aerocaliper"

# Region for Model Armor
MODEL_ARMOR_LOCATION="us-central1"

# The specific Model Armor template resource name
MODEL_ARMOR_TEMPLATE="aerocaliper-policy"
